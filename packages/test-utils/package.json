{
  "name": "@cc-room/test-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cc-room/shared": "workspace:*",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0",
    "tsup": "^8.1.0"
  }
}
